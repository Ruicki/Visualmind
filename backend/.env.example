# --- CONFIGURACIÓN DEL SERVIDOR ---
PORT=5000
NODE_ENV=development

# --- BASE DE DATOS (POSTGRESQL) ---
# Opción 1: URL directa (Recomendado para Railway/Render)
DATABASE_URL=postgresql://user:password@host:port/dbname

# Opción 2: Parámetros individuales (Local)
DB_USER=postgres
DB_PASSWORD=your_password
DB_HOST=localhost
DB_PORT=5432
DB_NAME=visualmind

# --- SEGURIDAD ---
# Una cadena aleatoria larga para firmar los JWT
JWT_SECRET=tu_secreto_super_seguro_aqui

# --- CORS (LISTA DE ORÍGENES PERMITIDOS) ---
# Separados por coma, sin espacios. Ejemplo: http://localhost:5173,https://visualmind.vercel.app
ALLOWED_ORIGINS=http://localhost:5173
